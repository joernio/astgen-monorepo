# astgen-regression configuration
# Generated by: astgen-regression init
project:
  name: "{{ project_name }}"
  language: "{{ language }}"
build:
{% if install_command %}
  install_command: "{{ install_command }}"
{% endif %}
  build_command: "{{ build_command }}"
  dist_dir: "{{ dist_dir }}"
execute:
  command: "{{ exec_command }}"
  timeout: 600  # seconds
artifacts:
{% for artifact in artifacts %}
  - name: "{{ artifact.name }}"
    pattern: "{{ artifact.pattern }}"
{% if artifact.description %}
    description: "{{ artifact.description }}"
{% endif %}
{% endfor %}
corpora:
  # Add your test corpora here. Example:
  # - name: "example-corpus"
  #   label: "org/repo@1.0.0"
  #   clone_url: "https://github.com/org/repo.git"
  #   tag: "1.0.0"
  #   input_subdir: "src"
github:
  base_branch: "{{ base_branch }}"
  python_version: "3.12"
{% if runs_on %}
  runs_on: "{{ runs_on }}"
{% endif %}
{% if setup_action %}
  setup_action:
    uses: "{{ setup_action.uses }}"
{% if setup_action.with %}
    with:
{% for key, value in setup_action.with.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% endif %}
